{
  "name": "pocketlint",
  "version": "0.1.0",
  "description": "PipeWire Audio Logical Y-Split Recorder and Pocket AI Uploader",
  "main": "main.js",
  "homepage": "https://github.com/paul/pocketlint",
  "author": "Paul <paul@example.com>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "node build-rpm.js"
  },
  "keywords": [
    "pipewire",
    "loopback",
    "audio",
    "recorder",
    "electron"
  ],
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.heypocket.pocketlint",
    "productName": "PocketLint",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "dir"
      ],
      "category": "AudioVideo",
      "executableName": "pocketlint",
      "maintainer": "Paul <paul@example.com>"
    }
  }
}
